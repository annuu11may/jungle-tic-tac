<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Jungle Tic Tac Toe</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background: linear-gradient(160deg, #071a07 0%, #0f3010 30%, #1a5a1a 60%, #0a2a0a 100%);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
}

.overlay{
    position:absolute;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.3);
}

.container{
    position:relative;
    z-index:2;
    width:95%;
    max-width:450px;
    background:rgba(20,40,20,0.88);
    border-radius:25px;
    padding:20px;
    color:white;
    box-shadow:0 0 20px rgba(0,0,0,0.5);
}

h1{
    text-align:center;
    margin-bottom:15px;
    color:#ffe066;
    font-size:38px;
}

.input-box{
    margin-bottom:15px;
}

input{
    width:100%;
    padding:12px;
    border:none;
    border-radius:12px;
    outline:none;
    font-size:16px;
}

.avatar-section{
    margin-top:15px;
}

.avatar-list{
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:10px;
    margin-top:10px;
}

.avatar{
    width:70px;
    height:70px;
    background:#355e3b;
    border-radius:15px;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:40px;
    cursor:pointer;
    transition:0.3s;
    border:3px solid transparent;
}

.avatar:hover{
    transform:scale(1.1);
}

.selected{
    border:3px solid yellow;
}

button{
    width:100%;
    padding:14px;
    margin-top:20px;
    border:none;
    border-radius:15px;
    background:#7cb518;
    color:white;
    font-size:20px;
    cursor:pointer;
    font-weight:bold;
}

button:hover{
    background:#55a630;
}

.game{
    display:none;
}

.info{
    display:flex;
    justify-content:space-between;
    margin-bottom:15px;
    font-size:18px;
}

.board{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:10px;
}

/* ✅ IMGUR HATAYA - CSS jungle wood texture lagaya */
.cell{
    height:100px;
    background: linear-gradient(135deg, #3b2006 0%, #5a3510 40%, #3b2006 100%);
    border-radius:15px;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:50px;
    cursor:pointer;
    color:white;
    border: 2px solid rgba(120,80,30,0.6);
    box-shadow: inset 0 0 10px rgba(0,0,0,0.4);
    transition: background 0.2s;
}

.cell:hover{
    background: linear-gradient(135deg, #4a2a08 0%, #6b4015 40%, #4a2a08 100%);
}

.scoreboard{
    margin-top:20px;
    background:rgba(255,255,255,0.1);
    padding:10px;
    border-radius:12px;
}

.history{
    margin-top:15px;
    max-height:120px;
    overflow:auto;
}

.history p{
    margin-bottom:5px;
    font-size:14px;
}

.result{
    text-align:center;
    font-size:28px;
    margin-top:15px;
    color:#ffd60a;
}

.animal-reaction{
    text-align:center;
    font-size:70px;
    margin-top:10px;
    animation:bounce 1s infinite;
}

@keyframes bounce{
    0%{transform:translateY(0);}
    50%{transform:translateY(-10px);}
    100%{transform:translateY(0);}
}

.leaf{
    position:absolute;
    font-size:20px;
    opacity:0.7;
    animation:fall 8s linear infinite;
    pointer-events:none;
}

@keyframes fall{
    0%{
        transform:translateY(-100px) rotate(0deg);
        opacity:0.7;
    }
    100%{
        transform:translateY(100vh) rotate(360deg);
        opacity:0;
    }
}
</style>
</head>

<body>

<div class="overlay"></div>

<div class="container">

<div id="menu">

<h1>🌴 Jungle Tic Tac Toe</h1>

<div class="input-box">
<input type="text" id="playerName" placeholder="Enter Your Name">
</div>

<div class="avatar-section">
<h3>Select Your Animal</h3>

<div class="avatar-list">
<div class="avatar" data-avatar="🦁">🦁</div>
<div class="avatar" data-avatar="🐘">🐘</div>
<div class="avatar" data-avatar="🐵">🐵</div>
<div class="avatar" data-avatar="🐯">🐯</div>
<div class="avatar" data-avatar="🦜">🦜</div>
</div>
</div>

<button onclick="startGame()">PLAY</button>

</div>

<div class="game" id="game">

<div class="info">
<div id="playerInfo"></div>
<div id="computerInfo"></div>
</div>

<div class="board" id="board"></div>

<div class="result" id="result"></div>

<div class="animal-reaction" id="reaction"></div>

<div class="scoreboard">
<h3>Scores</h3>
<p id="scoreText">Player: 0 | Computer: 0</p>
</div>

<div class="history" id="history">
<h3>Game History</h3>
</div>

<button onclick="restartGame()">Play Again</button>

</div>

</div>

<script>

const avatars = document.querySelectorAll(".avatar");

let playerAvatar = "";
let computerAvatar = "";
let playerName = "";
let board = ["","","","","","","","",""];
let currentTurn = "player";
let playerScore = 0;
let computerScore = 0;

const animals = ["🦁","🐘","🐵","🐯","🦜"];

avatars.forEach(avatar=>{
    avatar.addEventListener("click", ()=>{
        avatars.forEach(a=>a.classList.remove("selected"));
        avatar.classList.add("selected");
        playerAvatar = avatar.dataset.avatar;
    });
});

function startGame(){

    playerName = document.getElementById("playerName").value;

    if(playerName === ""){
        alert("Enter your name");
        return;
    }

    if(playerAvatar === ""){
        alert("Select an avatar");
        return;
    }

    let options = animals.filter(a=>a !== playerAvatar);
    computerAvatar = options[Math.floor(Math.random()*options.length)];

    document.getElementById("menu").style.display = "none";
    document.getElementById("game").style.display = "block";

    document.getElementById("playerInfo").innerHTML =
        `${playerName}: ${playerAvatar}`;

    document.getElementById("computerInfo").innerHTML =
        `Computer: ${computerAvatar}`;

    createBoard();
}

function createBoard(){

    const boardDiv = document.getElementById("board");
    boardDiv.innerHTML = "";

    board.forEach((cell,index)=>{

        const div = document.createElement("div");
        div.classList.add("cell");
        div.innerHTML = cell;

        div.addEventListener("click", ()=>playerMove(index));

        boardDiv.appendChild(div);
    });
}

function playerMove(index){

    if(board[index] !== "") return;

    board[index] = playerAvatar;

    createBoard();

    if(checkWinner(playerAvatar)){
        playerWins();
        return;
    }

    if(boardFull()){
        tieGame();
        return;
    }

    setTimeout(computerMove,700);
}

function computerMove(){

    let empty = board
        .map((val,index)=> val==="" ? index : null)
        .filter(v=>v!==null);

    let move = empty[Math.floor(Math.random()*empty.length)];

    board[move] = computerAvatar;

    createBoard();

    if(checkWinner(computerAvatar)){
        computerWins();
        return;
    }

    if(boardFull()){
        tieGame();
    }
}

function checkWinner(symbol){

    const wins = [
        [0,1,2],
        [3,4,5],
        [6,7,8],
        [0,3,6],
        [1,4,7],
        [2,5,8],
        [0,4,8],
        [2,4,6]
    ];

    return wins.some(combo=>{
        return combo.every(i=>board[i] === symbol);
    });
}

function boardFull(){
    return board.every(cell=>cell !== "");
}

function playerWins(){

    playerScore++;

    document.getElementById("result").innerHTML =
        `${playerName} Wins!`;

    document.getElementById("reaction").innerHTML = "🦁🎉";

    updateScore();

    addHistory("Win");
}

function computerWins(){

    computerScore++;

    document.getElementById("result").innerHTML =
        `Computer Wins!`;

    document.getElementById("reaction").innerHTML = "🐵😂";

    updateScore();

    addHistory("Lose");
}

function tieGame(){

    document.getElementById("result").innerHTML =
        "It's a Tie!";

    document.getElementById("reaction").innerHTML = "🐘🤝";

    addHistory("Tie");
}

function updateScore(){

    document.getElementById("scoreText").innerHTML =
        `Player: ${playerScore} | Computer: ${computerScore}`;
}

function restartGame(){

    board = ["","","","","","","","",""];

    document.getElementById("result").innerHTML = "";
    document.getElementById("reaction").innerHTML = "";

    createBoard();
}

function addHistory(result){

    const history = document.getElementById("history");

    const p = document.createElement("p");

    p.innerHTML =
        `${playerName} vs Computer → ${result}`;

    history.appendChild(p);
}

// ✅ Leaf emoji gir rahe hain - green circle nahi
const leafEmojis = ["🍃","🌿","🍀","🌱"];

for(let i=0;i<20;i++){

    let leaf = document.createElement("div");

    leaf.classList.add("leaf");
    leaf.textContent = leafEmojis[Math.floor(Math.random()*leafEmojis.length)];

    leaf.style.left = Math.random()*100 + "vw";
    leaf.style.animationDuration = 5 + Math.random()*5 + "s";
    leaf.style.animationDelay = Math.random()*5 + "s";

    document.body.appendChild(leaf);
}

</script>

</body>
</html>
